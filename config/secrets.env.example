# V35 Build Platform — Secrets Template
# Copier : cp config/secrets.env.example config/secrets.env
# JAMAIS commiter config/secrets.env (déjà dans .gitignore)
# ─────────────────────────────────────────────────────────────

# ── Cloudflare ────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=cfut_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── Images ────────────────────────────────────────────────────
# Watermark par défaut si le domaine n'est pas passé dans la requête
WATERMARK_TEXT=v35build.fr

# ── APIs externes ─────────────────────────────────────────────
# RapidAPI → AliExpress Datahub (market-intel margin calculator)
RAPIDAPI_KEY=

# Gemini (gemini-proxy) — clés séparées par virgule
GEMINI_KEYS=

# Mistral (content-ai)
MISTRAL_KEY=

# OpenRouter (vault-init-worker)
OR_KEY=

# ── Scraping proxies ──────────────────────────────────────────
# ScrapingBee — clés séparées par virgule (rotation automatique)
SCRAPINGBEE_KEYS=

# ZenRows — clés séparées par virgule
ZENROWS_KEYS=

# ── Auth interne ──────────────────────────────────────────────
# Token partagé entre workers (supplier-resolver ↔ build-api)
API_TOKEN=
SEED_SECRET=
